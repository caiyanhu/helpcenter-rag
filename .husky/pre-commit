#!/bin/sh
# Pre-commit hook: format code and run type checks
# Full tests run in CI on push/PR

echo "Running Prettier..."
npx prettier --write . || exit 1

echo "Running type checks..."
cd frontend && npx vue-tsc --noEmit || exit 1
cd ../backend && npx tsc --noEmit || exit 1
cd ../content-processor && npx tsc --noEmit || exit 1

echo "Pre-commit checks passed!"
